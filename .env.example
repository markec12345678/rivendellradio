# Rock 88.7 — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ───────────────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ─── Listener Privacy (REQUIRED for listener pipeline) ──
# Generate with: openssl rand -hex 32
# The pipeline refuses to store unhashed IPs without this salt.
LISTENER_HASH_SALT=generate-a-random-32-byte-hex-string-here

# ─── Voice TTS (OPTIONAL — upgrades voice quality) ─────
# Set this to use ElevenLabs (human-quality voice, $5/mo)
# Without it, the system uses Piper (free, natural neural voice)
# Get a key at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ─── Station Location (for weather) ─────────────────────
# Default: Ljubljana, Slovenia
STATION_LAT=46.0569
STATION_LON=14.5058
STATION_TIMEZONE=Europe/Ljubljana

# ─── Piper TTS Voices (for free offline TTS) ────────────
# Directory containing Piper .onnx voice models
# Download from: https://huggingface.co/rhasspy/piper-voices
PIPER_VOICES_DIR=/data/piper-voices

# ─── Icecast2 (for listener adapter) ────────────────────
ICECAST_URL=http://localhost:8000
ICECAST_MOUNT=/rock-887.mp3

# ─── Music Directory (for Docker volume mount) ──────────
MUSIC_DIR=./music

# ─── Public Stream URL (for web player) ─────────────────
ICECAST_PUBLIC_URL=http://localhost:8000/rock-887.mp3

# ─── Internal API Base (for governance endpoint) ────────
INTERNAL_API_BASE=http://localhost:3000
