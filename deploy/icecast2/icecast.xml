<icecast>
  <!-- ====================================================================== -->
  <!-- Rock 88.7 — Icecast2 Production Config                                  -->
  <!--                                                                        -->
  <!-- Quick start:                                                           -->
  <!--   1. sudo apt install icecast2                                         -->
  <!--   2. sudo cp icecast.xml /etc/icecast2/icecast.xml                     -->
  <!--   3. Change passwords below                                            -->
  <!--   4. sudo systemctl restart icecast2                                   -->
  <!--                                                                        -->
  <!-- Listeners connect to: http://your-server:8000/rock-887.mp3             -->
  <!-- Admin panel: http://your-server:8000/admin (admin/hackme)              -->
  <!-- ====================================================================== -->

  <location>Rock 88.7 FM Studio</location>
  <admin>icemaster@rock887.fm</admin>

  <limits>
    <clients>1000</clients>
    <sources>2</sources>
    <threadpool>5</threadpool>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>

  <authentication>
    <source-password>hackme</source-password>      <!-- CHANGE THIS — must match Liquidsoap -->
    <relay-password>hackme</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>hackme</admin-password>         <!-- CHANGE THIS -->
  </authentication>

  <hostname>stream.rock887.fm</hostname>

  <listen-socket>
    <port>8000</port>
    <bind-address>0.0.0.0</bind-address>
  </listen-socket>

  <!-- Enable listener stats — Rock 88.7 adapter needs this -->
  <listeners>
    <listener-stats>1</listener-stats>
  </listeners>

  <http-headers>
    <header name="Access-Control-Allow-Origin" value="*" />
    <header name="X-Frame-Options" value="SAMEORIGIN" />
  </http-headers>

  <paths>
    <basedir>/usr/share/icecast2</basedir>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
    <alias source="/" destination="/status.xsl"/>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
    <logsize>10000</logsize>
  </logging>

  <security>
    <chroot>0</chroot>
  </security>
</icecast>
