// Prisma schema — Rivendell Web Dashboard
// Phase 1: RBAC + Audit Trail + Broadcast API

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Configuration (existing)
// ============================================================================

model RivendellConfig {
  id        Int      @id @default(1)
  url       String   @default("http://localhost/rdxport.cgi")
  username  String?
  password  String?
  connected Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model ActiveStation {
  id        Int      @id @default(1)
  stationId String   @default("main-fm")
  updatedAt DateTime @updatedAt
}

model ThemePreference {
  id        Int      @id @default(1)
  mode      String   @default("dark")
  accentHue Int      @default(60)
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Phase 1: RBAC (Role-Based Access Control)
// ============================================================================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  fullName  String?
  role      String   @default("read-only") // admin | program-director | music-scheduler | news-editor | technical-engineer | traffic | producer | presenter | read-only
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
}

// ============================================================================
// Phase 1: Audit Trail
// ============================================================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // create | update | delete | login | logout | play | stop | rml | approve | reject
  entity    String   // track | log | schedule | station | config | request | voice-track | user
  entityId  String?
  details   String?  // JSON string with before/after values
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([timestamp])
}

// ============================================================================
// Phase 1: Broadcast API (API Keys)
// ============================================================================

model ApiKey {
  id          Int      @id @default(autoincrement())
  name        String   // e.g. "Newsroom Integration", "Mobile App"
  keyHash     String   @unique // SHA-256 hash of the API key
  keyPrefix   String   // First 8 chars for display (e.g. "rk_live_...")
  permissions String   // Comma-separated: "read:tracks,write:requests,read:schedule"
  active      Boolean  @default(true)
  lastUsed    DateTime?
  createdAt   DateTime @default(now())
  createdBy   String?
}

// ============================================================================
// Phase 2: Event Store (persistent event bus) + Webhooks
// ============================================================================

/// Persistent event store — vsak event na Event Bus-u se shrani v DB
model EventStore {
  id            Int      @id @default(autoincrement())
  eventId       String   @unique // UUID za deduplikacijo
  type          String   // track.started, rds.updated, itd.
  version       Int      @default(1) // event schema version
  source        String   // kateri modul je sprožil event
  correlationId String?  // za sledenje kaskadnim dogodkom
  data          String   // JSON string s payloadom
  timestamp     DateTime @default(now())

  @@index([type])
  @@index([correlationId])
  @@index([timestamp])
  @@index([source])
}

/// Webhook subscriptions — Event Bus → external systems (Discord, Slack, Spotify)
model Webhook {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  secret      String?
  events      String
  active      Boolean  @default(true)
  lastFired   DateTime?
  lastStatus  Int?
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())

  deliveries  WebhookDelivery[]
}

/// Webhook delivery attempts — za retry policy + DLQ
model WebhookDelivery {
  id           Int      @id @default(autoincrement())
  webhookId    Int
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventId      String
  eventType    String
  payload      String
  status       String   @default("pending")
  attemptCount Int      @default(0)
  lastStatus   Int?
  lastError    String?
  nextRetry    DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([webhookId])
  @@index([status])
  @@index([eventId])
}

// ============================================================================
// Phase 30: Listener Pipeline — real listener sessions from Icecast2.
// This table is EMPTY by design. It will remain empty until a real Icecast2
// server is connected and real sessions flow through the ingestion endpoint.
// See: src/lib/listener-pipeline/schema.ts
// See: docs/STATION-CHRONICLE.md — "The First Real Station Day"
// See: docs/EPISTEMOLOGICAL-INVARIANTS.md — Invariant 1 (Reality)
// ============================================================================

/// A real listener session, captured from a real streaming server.
/// source = 'measured' by definition. Never simulated, never demo.
model ListenerSession {
  id              String   @id // UUID v4, generated at ingestion
  startedAt       DateTime // ISO timestamp when listener connected
  endedAt         DateTime // ISO timestamp when listener disconnected
  durationMs      Int      // endedAt - startedAt, stored for query speed
  mount           String   // e.g. "/rock-887.mp3"
  listenerHash    String   // salted SHA-256 of IP — never the raw IP
  userAgent       String
  device          String   // derived from userAgent at ingestion
  geoRegion       String?
  referer         String?
  exitTrackId     String?
  exitTrackTitle  String?
  exitTrackArtist String?
  exitTrackPositionMs Int?
  daypart         String   // pre-computed at ingestion
  tracksPlayed    Int      @default(0)
  returning       Boolean  @default(false)
  source          String   @default("measured") // always 'measured' — see Invariant 1
  ingestedAt      DateTime @default(now())

  @@index([startedAt])
  @@index([endedAt])
  @@index([mount])
  @@index([daypart])
  @@index([listenerHash])
  @@index([device])
  @@index([returning])
}

// ============================================================================
// Phase 31: AI Governance & Trust Layer — Decision Ledger
// This table is EMPTY by design. It records AI-influenced decisions over time
// so the system can answer: "Was the AI right? Where? How often? By how much?"
//
// Each entry is a decision → outcome → lesson record. The lesson is DERIVED
// mechanically (never AI-authored, see Invariant 7). The outcome is MEASURED
// (source: 'measured', see Invariant 1).
//
// See: docs/EPISTEMOLOGICAL-INVARIANTS.md — Invariants 1, 2, 5, 6, 7
// See: src/lib/governance/ledger.ts
// ============================================================================

/// A single AI-influenced programming decision, tracked end-to-end.
/// Persists the AI's prediction (source: predicted), the human's choice
/// (source: human-asserted), and the measured outcome (source: measured).
model DecisionLedgerEntry {
  id String @id // DEC-00001 format, human-readable

  timestamp DateTime // when the decision was made
  context String // e.g. "morning-drive", "afternoon", "overnight"

  // The AI's proposal — source: 'predicted'. Never promoted to fact.
  aiRecommendation String
  aiReasoning String
  aiConfidence Float // 0-1, what the AI claimed
  aiPredictedAltDelta Float // min, predicted ALT change

  // The human's decision — source: 'human-asserted'
  humanDecision String // approved | overridden | not-consulted
  humanRationale String? // optional, why the human chose as they did
  actualAction String // what was actually done

  // The measured outcome — source: 'measured'. Null until measured.
  actualAltDelta Float? // min, null until the session data comes in
  measuredAt DateTime?

  // Derived — computed when the outcome is recorded. Never AI-authored.
  predictionError Float? // actualAltDelta - aiPredictedAltDelta (signed)
  sourceType String @default("simulated") // simulated | observed | experiment | validated
  lesson String? // mechanically derived, see deriveLedgerLesson()

  // Categorization for analytics
  decisionDomain String // music | voice-link | ad-strategy | schedule | format
  rejectionReason String? // if overridden: timing | brand | local-knowledge | risk | other

  ingestedAt DateTime @default(now())

  @@index([timestamp])
  @@index([context])
  @@index([humanDecision])
  @@index([decisionDomain])
  @@index([sourceType])
}

// ============================================================================
// Phase 3: EAS/CAP Compliance (FCC 47 CFR Part 11 + OASIS CAP 1.2)
// ============================================================================

/// CAP 1.2 alert — ingestiran iz FEMA IPAWS-OPEN ali lokalnega EAS dekoderja.
/// Spec: OASIS CAP 1.2 (https://docs.oasis-open.org/emergency/cap/v1.2/CAP-v1.2.html)
model CapAlert {
  id          Int      @id @default(autoincrement())
  identifier  String   // CAP <identifier> — unikatno per sender
  sender      String   // CAP <sender> — IPAWS COG ID ali lokalni sender
  sent        DateTime // CAP <sent> — timestamp originalnega alerta
  status      String   // CAP <status>: Actual | Exercise | System | Test | Draft
  msgType     String   // CAP <msgType>: Alert | Update | Cancel | Ack | Error
  scope       String   // CAP <scope>: Public | Restricted | Private
  source      String?  // CAP <source> — humano berljiv source
  code        String?  // CAP <code> — npr. "IPAWSv1.0"
  infoXml     String   // original <info> blok kot JSON (lahko več jezikov)
  category    String?  // Geo/Met/Safety/Security/Rescue/Fire/Env/Transport/Infra/CBRNE/Other
  event       String?  // npr. "Tornado Warning", "Required Weekly Test"
  urgency     String?  // Immediate | Expected | Future | Past | Unknown
  severity    String?  // Extreme | Severe | Moderate | Minor | Unknown
  certainty   String?  // Observed | Likely | Possible | Unlikely | Unknown
  effective   DateTime? // kdaj alert začne veljati
  onset       DateTime? // kdaj se pojavi
  expires     DateTime? // kdaj poteče
  areaDesc    String?  // CAP <areaDesc> — geografski opis
  geocode     String?  // CAP <geocode> — SAME/FIPS kode kot JSON
  parameters  String?  // CAP <parameter> — BHZ5, FLW, itd. kot JSON
  // Signature verification
  signatureValid Boolean @default(false)
  signatureError  String?
  rawXml      String   // originalen CAP XML za audit
  // Routing
  origin     String   // ipaws | local | manual | test
  receivedAt DateTime @default(now())
  // Povezava z EasLog (1:1 — en alert = en log entry po ingestu)
  easLog     EasLog?   @relation("CapAlertEasLog")

  @@unique([sender, identifier])
  @@index([sent])
  @@index([severity])
  @@index([status])
  @@index([expires])
  @@index([receivedAt])
}

/// FCC EAS log — 47 CFR §11.35 zahteva evidenco vseh EAS dogodkov.
/// Retencija: 4 leta (FCC zahteva). Cron job briše starejše.
model EasLog {
  id          Int      @id @default(autoincrement())
  // Povezava s CAP alertom (lahko je null za ročne/testne dogodke)
  capAlertId  Int?     @unique
  capAlert    CapAlert? @relation("CapAlertEasLog", fields: [capAlertId], references: [id])
  // Event classification
  eventType   String   // received | test | sent | interrupted | ignored | manual | weekly-test | monthly-test
  alertId     String?  // reference na <identifier>
  originator  String?  // kdo je sprožil (FCC origination code)
  decoderId   String?  // kateri dekoder/encoder je prejel (DASDEC-III, SAGE ENDEC)
  // Timing
  receivedAt  DateTime @default(now())
  durationMs  Int?     // koliko časa je trajala oddaja alerta
  // Operator info
  operatorId  String?  // kateri uporabnik je potrdil/akciral
  // Result
  result      String   // success | failed | ignored | pending
  resultDetail String? // npr. "broadcast interrupted 45s", "duplicate ignored"
  // FCC compliance fields
  fccStatusCode String? // SAME originator code (EAN, EAT, NPT, RMT, RWT, etc.)
  sameCode      String? // SAME event code (TOR, SVR, FFW, RWT, RMT, etc.)
  // Audit
  notes       String?

  @@index([eventType])
  @@index([receivedAt])
  @@index([result])
}
