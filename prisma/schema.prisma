// Prisma schema — Rivendell Web Dashboard
// Shranjuje: RDXport connection config, active station, theme preference

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// RDXport connection configuration (single row, id=1)
model RivendellConfig {
  id        Int      @id @default(1)
  url       String   @default("http://localhost/rdxport.cgi")
  username  String?
  password  String?
  connected Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

/// Active station selection (multi-station dashboard)
model ActiveStation {
  id        Int      @id @default(1)
  stationId String   @default("main-fm")
  updatedAt DateTime @updatedAt
}

/// Theme preference (dark/metal/light + accent hue)
model ThemePreference {
  id        Int      @id @default(1)
  mode      String   @default("dark")
  accentHue Int      @default(60)
  updatedAt DateTime @updatedAt
}
