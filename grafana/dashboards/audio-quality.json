  "panels": [
    {
      "id": 1,
      "title": "LUFS Integrated (EBU R128 target = -23 LUFS)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "min": -30,
          "max": -10,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": -25},
              {"color": "green", "value": -24},
              {"color": "yellow", "value": -22},
              {"color": "red", "value": -21}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "audio_lufs_integrated",
         "legendFormat": "integrated LUFS", "range": true, "instant": true}
      ]
    },
    {
      "id": 2,
      "title": "LUFS Short-Term (3-second windows)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 16, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "LUFS",
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "continuous-GrYlRd"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": -25},
              {"color": "green", "value": -24},
              {"color": "yellow", "value": -22},
              {"color": "red", "value": -21}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "mean", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "audio_lufs_shortterm",
         "legendFormat": "short-term LUFS ({{station}})", "range": true}
      ]
    },
    {
      "id": 3,
      "title": "True Peak (dBFS, EBU R128 S1 max = -1 dBFS)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "min": -12,
          "max": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": -1},
              {"color": "red", "value": 0}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
