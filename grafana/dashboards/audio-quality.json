      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "increase(silence_events_total[1h])",
         "legendFormat": "silence events (1h)", "range": true, "instant": true}
      ]
    },
    {
      "id": 5,
      "title": "GPIO Relay State (on-air / off-air / aux)",
      "type": "state-timeline",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 9},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "OFF", "color": "red"}, "1": {"text": "ON-AIR", "color": "green"}, "2": {"text": "AUX", "color": "yellow"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]},
          "color": {"mode": "fixed", "fixedColor": "green"}
