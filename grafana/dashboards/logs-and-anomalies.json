  "description": "Centralised log stream + anomaly view for the Rock 88.7 broadcast control center. Aggregates Next.js, broadcast-feed, Docker container, and systemd journal logs shipped by Promtail into Loki.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "title": "Log Stream (all rock887 services)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "wrapLogMessage": true,
            "showCommonFields": false,
            "showLabels": true,
            "showTime": true,
            "sortOrder": "Descending",
            "limit": 500,
            "dedupStrategy": "none"
          }
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonFields": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "limit": 500,
        "search": "",
        "timezone": {
          "field": ""
        },
        "capability": {
          "dedup": true,
          "label": true,
          "time": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=~\"rock887.*\"}",
          "queryType": "instant",
          "maxLines": 500
        }
      ],
      "timeFrom": null,
      "timeShift": null
    },
    {
      "id": 2,
      "title": "Error Rate Over Time (nextjs, 5m buckets)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "errors / 5m",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "errors",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (service) (count_over_time({source=\"nextjs\"} |= \"error\" [5m]))",
          "queryType": "range",
          "legendFormat": "{{service}}"
        }
      ],
      "timeFrom": null,
      "timeShift": null
    },
    {
