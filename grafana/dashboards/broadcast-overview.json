{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Top-level operational view of the Rock 88.7 broadcast control center: listeners, event bus, webhooks, AI, API, uptime.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Listener Count Trend (total + per-station)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {"mode": "normal", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "listeners",
            "scaleDistribution": {"type": "linear"},
            "hideFrom": {"tooltip": false, "viz": false, "legend": false}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "total"}, "properties": [
            {"id": "custom.stacking", "value": {"mode": "none", "group": "A"}},
            {"id": "custom.lineWidth", "value": 3},
            {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}
          ]}
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "sum(listeners_total)",
         "legendFormat": "total", "range": true},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "listeners_total{station!=\"\"}",
         "legendFormat": "{{station}}", "range": true}
      ]
    },
    {
      "id": 2,
      "title": "AI Module Runs per Minute",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 70,
            "gradientMode": "hue",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "normal", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "runs / min",
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "sum by (module) (rate(ai_module_runs_total[1m]) * 60)",
         "legendFormat": "{{module}}", "range": true}
      ]
    },
    {
      "id": 3,
      "title": "Event Bus Throughput (events / s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "events / s",
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "continuous-GrYlRd"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "rate(events_total[1m])",
         "legendFormat": "published / s", "range": true},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "rate(events_failed[1m])",
         "legendFormat": "failed / s", "range": true},
        {"refId": "C", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "rate(events_by_type[1m])",
         "legendFormat": "{{type}} / s", "range": true}
      ]
    },
    {
      "id": 4,
      "title": "Webhook Success / Fail Rate (5-min)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "rate",
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.9},
            {"color": "green", "value": 0.97}
          ]}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "(rate(webhook_deliveries[5m]) - rate(webhook_failures[5m])) / clamp_min(rate(webhook_deliveries[5m]), 1)",
         "legendFormat": "success rate", "range": true},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "rate(webhook_failures[5m]) / clamp_min(rate(webhook_deliveries[5m]), 1)",
         "legendFormat": "fail rate", "range": true}
      ]
    },
    {
      "id": 5,
      "title": "API Request Rate (req / s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "normal", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "req / s",
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "5xx"}, "properties": [
            {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
          ]},
          {"matcher": {"id": "byRegexp", "options": "4xx"}, "properties": [
            {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}
          ]}
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "sum by (status) (rate(http_requests_total[1m]))",
         "legendFormat": "{{status}}", "range": true}
      ]
    },
    {
      "id": 6,
      "title": "System Uptime",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 60},
            {"color": "green", "value": 3600}
          ]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "percentChangeColorMode": "standard"
      },
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"},
         "expr": "uptime_seconds",
         "legendFormat": "uptime", "range": true, "instant": true}
      ]
    }
  ],
